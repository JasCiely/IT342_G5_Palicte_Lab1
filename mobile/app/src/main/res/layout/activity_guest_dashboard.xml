<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/brand_burgundy"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Welcome Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome, Guest!"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:text="Browse our collection and discover your perfect outfit."
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Browse Outfits Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBrowseOutfits"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Browse Outfits"
                    android:textColor="@color/brand_burgundy"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_shopping_bag"
                    app:iconTint="@color/brand_burgundy"
                    app:iconSize="16dp"
                    app:iconPadding="6dp" />

                <!-- Sign In Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHeaderSignIn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Sign In"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:strokeColor="#FFFFFF"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── Guest Banner ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF8E7"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You're Browsing as a Guest"
                android:textColor="#92400E"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Create an account to unlock bookings, save favorites, and get exclusive rental deals!"
                android:textColor="#B45309"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAccountBanner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/brand_burgundy"
                android:text="CREATE ACCOUNT"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- ── Stats Grid ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="3">

            <!-- Stat 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100+"
                    android:textColor="@color/brand_burgundy"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Outfits"
                    android:textColor="@color/brand_text_subtitle"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Stat 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50+"
                    android:textColor="@color/brand_burgundy"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Brands"
                    android:textColor="@color/brand_text_subtitle"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Stat 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱200"
                    android:textColor="@color/brand_burgundy"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="From"
                    android:textColor="@color/brand_text_subtitle"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Sample Bookings (Locked) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sample Bookings"
                android:textColor="@color/brand_text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to view and manage your bookings"
                android:textColor="@color/brand_text_subtitle"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <!-- Locked Booking Card 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/brand_text_subtitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="SIGN IN TO VIEW"
                    android:textColor="@color/brand_text_subtitle"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Locked Booking Card 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/brand_text_subtitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="SIGN IN TO VIEW"
                    android:textColor="@color/brand_text_subtitle"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Popular Picks ── -->
        <LinearLayout
            android:id="@+id/sectionPopularPicks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Popular Picks"
                    android:textColor="@color/brand_text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all →"
                    android:textColor="@color/brand_burgundy"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Outfit Card 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:padding="12dp">

                <View
                    android:layout_width="70dp"
                    android:layout_height="90dp"
                    android:background="@color/brand_cream_bg" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Floral Elegance Gown"
                        android:textColor="@color/brand_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="★★★★★"
                        android:textColor="#F59E0B"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="₱3,500"
                        android:textColor="@color/brand_burgundy"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookOutfit1"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/brand_burgundy"
                        android:text="SIGN IN TO BOOK"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Outfit Card 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:padding="12dp">

                <View
                    android:layout_width="70dp"
                    android:layout_height="90dp"
                    android:background="@color/brand_cream_bg" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barong Tagalog"
                        android:textColor="@color/brand_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="★★★★☆"
                        android:textColor="#F59E0B"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="₱2,800"
                        android:textColor="@color/brand_burgundy"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookOutfit2"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/brand_burgundy"
                        android:text="SIGN IN TO BOOK"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Outfit Card 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:padding="12dp">

                <View
                    android:layout_width="70dp"
                    android:layout_height="90dp"
                    android:background="@color/brand_cream_bg" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Midnight Sapphire Dress"
                        android:textColor="@color/brand_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="★★★★★"
                        android:textColor="#F59E0B"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="₱4,200"
                        android:textColor="@color/brand_burgundy"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookOutfit3"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/brand_burgundy"
                        android:text="SIGN IN TO BOOK"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ── Bottom CTA ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Ready to book your perfect outfit?"
                android:textColor="@color/brand_text_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:text="Join thousands of happy customers renting premium outfits"
                android:textColor="@color/brand_text_subtitle"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAccountCta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@color/brand_burgundy"
                android:text="CREATE ACCOUNT  →"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignInCta"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="ALREADY HAVE AN ACCOUNT? SIGN IN"
                android:textColor="@color/brand_burgundy"
                android:textSize="12sp"
                app:strokeColor="@color/brand_burgundy"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>